{
  "name": "campus-skill-exchange-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for Campus Skill Exchange Network",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "build": "npx prisma generate && npx prisma migrate deploy",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.9.0",
    "vitest": "^3.2.1"
  }
}

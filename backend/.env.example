# Database - PRODUCTION (PostgreSQL on Render/Railway/Neon/Supabase)
# Set this in your cloud platform's environment variables dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# For LOCAL development only - if you have PostgreSQL installed locally:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/campus_skill_exchange"

# JWT
JWT_SECRET=campus-skill-exchange-dev-secret-key-32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=campus-skill-exchange-dev-refresh-secret-32c
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Backend environment variables for Campus Skill Exchange API
# Copy this file to backend/.env and fill in real values.

# Database connection string for Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT secrets must be strong and kept private
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_at_least_32_chars_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Backend runtime settings
PORT=3001
NODE_ENV=development

# Frontend origin allowed by CORS and email links
FRONTEND_URL=http://localhost:5173
